{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mowgli Hyperparameters",
  "type": "object",
  "properties": {
    "device": { "type": "string", "enum": ["cpu", "cuda", "cuda:0"], "default": "cpu" },
    "latent_dimensions": { "type": "integer", "minimum": 2, "default": 20 },
    "optimizer": { "type": "string", "enum": ["adam", "sgd", "adamw"], "default": "adam" },
    "learning_rate": { "type": "number", "exclusiveMinimum": 0, "default": 0.001 },
    "tol_inner": { "type": "number", "exclusiveMinimum": 0, "default": 1e-6 },
    "max_iter_inner": { "type": "integer", "minimum": 1, "default": 500 },
    "umap_random_state": { "type": "integer", "minimum": 0, "default": 42 },
    "umap_color_type": { "type": "string", "default": "cell_type" }
  },
  "additionalProperties": false
}
