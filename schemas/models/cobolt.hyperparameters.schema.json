{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cobolt Hyperparameters",
  "type": "object",
  "properties": {
    "device": { "type": "string", "enum": ["cpu", "cuda", "cuda:0"], "default": "cpu" },
    "latent_dimensions": { "type": "integer", "minimum": 2, "default": 20 },
    "learning_rate": { "type": "number", "exclusiveMinimum": 0, "default": 0.001 },
    "num_epochs": { "type": "integer", "minimum": 1, "default": 200 },
    "umap_random_state": { "type": "integer", "minimum": 0, "default": 42 },
    "umap_color_type": { "type": "string", "default": "cell_type" },
    "random_state": { "type": "integer", "minimum": 0, "default": 42 }
  },
  "additionalProperties": false
}
