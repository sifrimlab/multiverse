{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PCA Hyperparameters",
  "type": "object",
  "properties": {
    "n_components": { "type": "integer", "minimum": 2, "default": 50 },
    "device": { "type": "string", "enum": ["cpu", "cuda", "cuda:0"], "default": "cpu" },
    "umap_random_state": { "type": "integer", "minimum": 0, "default": 42 },
    "umap_color_type": { "type": "string", "default": "cell_type" }
  },
  "additionalProperties": false
}
