{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MOFA Hyperparameters",
  "type": "object",
  "properties": {
    "device": { "type": "string", "enum": ["cpu", "cuda", "cuda:0"], "default": "cpu" },
    "n_iterations": { "type": "integer", "minimum": 1, "default": 5000 },
    "n_factors": { "type": "integer", "minimum": 2, "default": 20 },
    "umap_random_state": { "type": "integer", "minimum": 0, "default": 42 },
    "umap_color_type": { "type": "string", "default": "cell_type" }
  },
  "additionalProperties": false
}
