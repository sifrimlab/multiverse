{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multiverse.local/schemas/hyperparameters.schema.json",
  "title": "Model Hyperparameters",
  "description": "Generic hyperparameter schema referenced by model manifests.",
  "type": "object",
  "properties": {
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "learning_rate": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "max_epochs": {
      "type": "integer",
      "minimum": 1
    },
    "latent_dimensions": {
      "type": "integer",
      "minimum": 2
    },
    "device": {
      "type": "string",
      "enum": [
        "cpu",
        "cuda",
        "cuda:0"
      ]
    }
  },
  "additionalProperties": true
}
